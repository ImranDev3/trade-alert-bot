# ============================================================
# trade-alert-bot — environment template
# Copy this file to ".env" and fill in your real values.
# NEVER commit your real .env file (it is git-ignored).
# ============================================================

# --- REQUIRED ---
# Get this from @BotFather on Telegram (see README).
TELEGRAM_BOT_TOKEN=

# --- OPTIONAL ---
# How often (in seconds) the bot checks alerts against live prices.
POLL_INTERVAL_SECONDS=60

# How often (in seconds) each user's watchlist prices are broadcast.
WATCHLIST_UPDATE_INTERVAL=300

# When the daily digest fires, as "HH:MM" in 24h local time.
# Leave blank to disable the daily summary.
# Example: 09:00  -> 9am every day
DAILY_SUMMARY_TIME=

# How fresh (in seconds) a cached realtime price must be to be used.
CACHE_TTL_SECONDS=30

# How often (seconds) the bot pulls new RSS headlines for auto news drops.
NEWS_DROP_INTERVAL=60

# How often (seconds) the liquidation digest is sent (per-minute recheck).
LIQUIDATION_DIGEST_INTERVAL=60

# 1 = every user the bot has ever seen gets news auto-drops by default
#     (use /newsauto off to opt out). 0 = users must run /newsauto on.
NEWS_AUTO_SUBSCRIBE_ALL=1

# Comma-separated list of Telegram user IDs allowed to use the bot.
# Leave blank to allow everyone (useful for testing).
# Tip: message @userinfobot on Telegram to find your numeric ID.
ALLOWED_USER_IDS=
