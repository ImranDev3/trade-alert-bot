# ============================================================
# trade-alert-bot — environment template
# Copy this file to ".env" and fill in your real values.
# NEVER commit your real .env file (it is git-ignored).
# ============================================================

# --- REQUIRED ---
# Get this from @BotFather on Telegram (see README).
TELEGRAM_BOT_TOKEN=

# --- OPTIONAL ---
# How often (in seconds) the bot checks alerts against live prices.
POLL_INTERVAL_SECONDS=60

# Comma-separated list of Telegram user IDs allowed to use the bot.
# Leave blank to allow everyone (useful for testing).
# Tip: message @userinfobot on Telegram to find your numeric ID.
ALLOWED_USER_IDS=
